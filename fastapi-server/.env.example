# 开发模式（生产环境必须设为 false）
DEBUG=false

# 数据库（开发默认 SQLite）
DATABASE_URL=sqlite+aiosqlite:///./laborlaw.db

# JWT（⚠️ 部署时必须改为随机字符串！例如用 openssl rand -hex 32 生成）
JWT_SECRET_KEY=change-me-in-production

# ── AI 适配器（必填！否则 AI 分析无法工作） ──
# 支持任意 OpenAI 兼容接口：DeepSeek / 通义千问 / 智谱GLM / Moonshot / OpenAI 等
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── 可选配置 ──
# 微信开放平台（登录功能需要）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 微信支付（付费功能需要）
WXPAY_MCH_ID=
WXPAY_API_KEY=
WXPAY_NOTIFY_URL=
